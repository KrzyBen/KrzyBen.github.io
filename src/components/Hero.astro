---
import background from '../assets/background.svg';
---

<section class="hero">
  <img src={background.src} alt="Fondo" class="background" />
  
  <div class="content">
    <div class="badge">Universidad del Bío-Bío • 2026</div>
    
    <h1>SRAACV</h1>
    <p class="subtitle">
      Sistema móvil para el registro y análisis automatizado<br>
      de conductas vehiculares imprudentes mediante IA
    </p>
    
    <p class="author">
      Benjamín Antonio Manríquez Ramírez<br>
      <span class="career">Ingeniería en Ejecución en Computación e Informática</span>
    </p>

    <div class="buttons">
      <a href="#propuesta" class="btn-primary">Conoce el proyecto</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: #ffffff;
  }
  .background {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: -1;
    filter: blur(100px) brightness(0.35);   /* ← más oscuro */
  }
  .content {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
    z-index: 2;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(12px);
    padding: 10px 24px;
    border-radius: 9999px;
    font-size: 1rem;
    margin-bottom: 2rem;
  }
  h1 {
    font-size: 4.8rem;
    line-height: 1.05;
    font-weight: 700;
    margin: 0 0 1rem;
  }
  .subtitle {
    font-size: 1.75rem;
    line-height: 1.3;
    color: #93c5fd;
    margin-bottom: 2.5rem;
  }
  .author {
    font-size: 1.35rem;
    color: #cbd5e1;
    margin-bottom: 2.5rem;
  }
  .career {
    color: #60a5fa;
  }
  .buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .btn-primary {
    background: #2563eb;
    color: white;
    padding: 16px 36px;
    border-radius: 9999px;
    font-weight: 600;
    text-decoration: none;
    font-size: 1.15rem;
  }
  .btn-secondary {
    border: 2px solid rgba(255,255,255,0.7);
    color: white;
    padding: 16px 36px;
    border-radius: 9999px;
    font-weight: 600;
    text-decoration: none;
    font-size: 1.15rem;
  }
  @media (max-width: 640px) {
    h1 { font-size: 3.2rem; }
    .subtitle { font-size: 1.45rem; }
  }
</style>