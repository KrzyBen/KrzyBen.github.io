---
import background from '../assets/background.svg';
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <img 
    src={background.src} 
    alt="Fondo" 
    class="absolute inset-0 w-full h-full object-cover z-[-1] filter blur-[100px] brightness-50"
  />
  
  <div class="max-w-5xl mx-auto px-6 pt-20 pb-16 relative z-10">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md px-5 py-2 rounded-3xl text-sm font-medium mb-6">
        📍 Universidad del Bío-Bío • 2026
      </div>
      
      <h1 class="text-6xl md:text-7xl font-bold leading-none tracking-tighter">
        SRAACV
      </h1>
      <p class="text-2xl md:text-3xl text-blue-300 mt-4">
        Sistema móvil para el registro y análisis automatizado<br>
        de conductas vehiculares imprudentes mediante IA
      </p>
      
      <p class="mt-8 text-xl text-gray-300">
        Benjamín Antonio Manríquez Ramírez<br>
        <span class="text-blue-400">Ingeniería en Ejecución en Computación e Informática</span>
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#propuesta" class="bg-blue-600 hover:bg-blue-700 transition px-8 py-4 rounded-2xl font-semibold text-lg">
          Conoce el proyecto
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-xs tracking-widest opacity-50 flex items-center gap-2">
    DESPLAZA PARA VER MÁS ↓
  </div>
</section>