---
const stats = [
  { label: "Siniestros ene-mar 2025", value: "17.674" },
  { label: "Fallecidos", value: "410 (+3,3%)" },
  { label: "Imprudencia del conductor", value: "69,1%" },
];
---

<section id="problema" class="section dark">
  <div class="container">
    <div class="max-w-2xl">
      <h2>Problemática</h2>
      <p class="intro">La seguridad vial en Chile sigue siendo un grave problema de salud pública y una carga económica significativa para el país.</p>
    </div>

    <div class="stats-grid">
      {stats.map(stat => (
        <div class="stat-card">
          <p class="value">{stat.value}</p>
          <p class="label">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section.dark { padding: 5rem 0; background: #111827; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  h2 { font-size: 2.75rem; font-weight: 700; margin-bottom: 1rem; }
  .intro { font-size: 1.25rem; color: #94a3b8; max-width: 600px; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 3.5rem;
  }
  .stat-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  .value {
    font-size: 3.8rem;
    font-weight: 700;
    color: #60a5fa;
    margin: 0;
  }
  .label { margin-top: 1rem; color: #cbd5e1; font-size: 1.15rem; }
</style>