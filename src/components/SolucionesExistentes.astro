---
const apps = [
  { 
    name: "Nexar Connect", 
    price: "$9.99 USD/mes", 
    desc: "Detección de incidentes y almacenamiento en la nube", 
    url: "https://apps.apple.com/us/app/nexar-classic/id996931497" 
  },
  { 
    name: "Driver: Driving & Dash Cam", 
    price: "$8–13 USD", 
    desc: "IA para frenazos y colisiones (solo EE.UU.)", 
    url: "https://apps.apple.com/us/app/driver-driving-dash-cam-app/id1415557883" 
  },
  { 
    name: "DashcamUA", 
    price: "Gratis (con publicidad)", 
    desc: "Reconocimiento de patentes y reportes anónimos", 
    url: "https://apps.apple.com/ua/app/dashcamua/id1542510318" 
  },
];
---

<section id="soluciones" class="section">
  <div class="container">
    <h2>Soluciones existentes</h2>
    <div class="apps-grid">
      {apps.map(app => (
        <a href={app.url} target="_blank" rel="noopener noreferrer" class="app-card">
          <h3>{app.name}</h3>
          <p class="price">{app.price}</p>
          <p class="desc">{app.desc}</p>
          <span class="link-text">Ver en App Store →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 5rem 0; background: #0f172a; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  h2 { font-size: 2.75rem; font-weight: 700; margin-bottom: 2rem; text-align: center; }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }
  .app-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 2rem;
    display: block;
    color: inherit;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
  }
  .app-card:hover {
    transform: translateY(-6px);
    border-color: #60a5fa;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  .app-card h3 { font-size: 1.5rem; margin: 0 0 0.5rem; }
  .price { color: #60a5fa; margin-bottom: 1rem; }
  .desc { color: #cbd5e1; margin-bottom: 1.5rem; line-height: 1.4; }
  .link-text {
    font-size: 0.95rem;
    color: #60a5fa;
    opacity: 0;
    transition: all 0.3s;
    display: block;
    margin-top: 1rem;
  }
  .app-card:hover .link-text { opacity: 1; }
</style>