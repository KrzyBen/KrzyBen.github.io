---
const categorias = [
  {
    label: 'App Móvil',
    items: [
      { name: 'Kotlin', role: 'Lenguaje principal', color: '#ede9fe', icon: '🟣' },
      { name: 'CameraX', role: 'Grabación dashcam', color: '#e0f2fe', icon: '📷' },
    ]
  },
  {
    label: 'Servidor',
    items: [
      { name: 'Node.js', role: 'Backend', color: '#e0f2fe', icon: '🟦' },
      { name: 'Express', role: 'API', color: '#ede9fe', icon: '⚡' },
      { name: 'PostgreSQL', role: 'Base de datos', color: '#e8f5e9', icon: '🐘' },
    ]
  },
  {
    label: 'Inteligencia Artificial',
    items: [
      { name: 'YOLOv8', role: 'Detección en tiempo real', color: '#fff3e0', icon: '👁️' },
      { name: 'EasyOCR', role: 'Lectura de patentes', color: '#fce7f3', icon: '🔤' },
      { name: 'Ollama', role: 'Generación de reportes', color: '#e8eaf6', icon: '🤖' },
    ]
  },
];
---

<section id="tecnologias" class="section">
  <div class="container">
    <h2>Posible Stack Tecnológico</h2>
    <div class="categorias-grid">
      {categorias.map(cat => (
        <div class="categoria">
          <span class="cat-label">{cat.label}</span>
          <div class="cards">
            {cat.items.map(item => (
              <div class="tech-card">
                <div class="icon" style={`background: ${item.color}`}>{item.icon}</div>
                <div class="info">
                  <p class="name">{item.name}</p>
                  <p class="role">{item.role}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section { padding: 5rem 0; background: transparent; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  h2 { font-size: 2.5rem; font-weight: 700; margin-bottom: 2.5rem; text-align: center; }
  
  .categorias-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }
  .categoria { }
  .cat-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #60a5fa;
    margin-bottom: 1rem;
  }
  .cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .tech-card {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s;
  }
  .tech-card:hover {
    transform: translateY(-3px);
    border-color: #60a5fa;
  }
  .icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    flex-shrink: 0;
  }
  .info .name {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
  }
  .info .role {
    font-size: 0.9rem;
    color: #94a3b8;
    margin: 0;
  }
</style>
