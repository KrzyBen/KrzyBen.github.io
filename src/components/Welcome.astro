---
import background from '../assets/background.svg';

const categories = [
  {
    label: 'App móvil',
    items: [
      { name: 'Kotlin',   role: 'Lenguaje principal', color: '#ede9fe', icon: '🟣' },
      { name: 'CameraX',  role: 'Grabación dashcam',  color: '#e0f2fe', icon: '📷' },
    ]
  },
  {
    label: 'Servidor',
    items: [
      { name: 'Node.js',        role: 'Backend runtime', color: '#e0f2fe', icon: '🟦' },
      { name: 'Express',        role: 'API framework',   color: '#ede9fe', icon: '⚡' },
      { name: 'BullMQ + Redis', role: 'Job queue',       color: '#fce7f3', icon: '⚙️' },
      { name: 'PostgreSQL',     role: 'Database',        color: '#e8f5e9', icon: '🐘' },
    ]
  },
  {
    label: 'IA local',
    items: [
      { name: 'YOLOv8',         role: 'Detección visual',  color: '#fff3e0', icon: '👁️' },
      { name: 'EasyOCR',        role: 'Lectura patentes',  color: '#fce7f3', icon: '🔤' },
      { name: 'FFmpeg',         role: 'Extracción frames', color: '#f3e5f5', icon: '🎞️' },
      { name: 'Ollama / LLaMA', role: 'Reportes IA',      color: '#e8eaf6', icon: '🤖' },
    ]
  },
];
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <main>
    <section id="hero">
      <span id="badge">Construido con Astro</span>
      <h1>KrzyBen Stack</h1>
      <p>Tecnología con la que podría trabajar</p>

      <div id="categories">
        {categories.map(cat => (
          <div class="category">
            <span class="cat-label">{cat.label}</span>
            <div class="grid">
              {cat.items.map(item => (
                <div class="card">
                  <div class="icon" style={`background:${item.color}`}>{item.icon}</div>
                  <span class="name">{item.name}</span>
                  <span class="role">{item.role}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>

</div>

<style>
  #background {
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: -1; filter: blur(100px);
  }
  #container {
    font-family: Inter, Roboto, 'Helvetica Neue', Arial, sans-serif;
    min-height: 100vh;
  }
  main {
    display: flex;
    justify-content: center;
    padding: 2rem 1rem 6rem;
  }
  #hero {
    display: flex; flex-direction: column;
    align-items: flex-start; gap: 12px;
    max-width: 700px; width: 100%;
  }
  #badge {
    background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
    color: white; font-size: 0.7rem; font-weight: 600;
    padding: 3px 12px; border-radius: 20px;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  h1 { font-size: 1.8rem; margin: 0; color: #111827; }
  #hero > p { font-size: 1rem; color: #6b7280; margin: 0; }

  #categories {
    display: flex; flex-direction: column;
    gap: 20px; width: 100%; margin-top: 8px;
  }
  .category { display: flex; flex-direction: column; gap: 8px; }
  .cat-label {
    font-size: 0.72rem; font-weight: 600; color: #6b7280;
    text-transform: uppercase; letter-spacing: 0.08em;
    padding-left: 2px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 10px;
  }
  .card {
    background: rgba(255,255,255,0.85);
    border: 1px solid rgba(255,255,255,0.9);
    border-radius: 14px; padding: 12px 10px;
    display: flex; flex-direction: column;
    align-items: center; gap: 6px;
    backdrop-filter: blur(10px);
    transition: transform 0.2s;
  }
  .card:hover { transform: translateY(-3px); }
  .icon {
    width: 36px; height: 36px; border-radius: 9px;
    display: flex; align-items: center;
    justify-content: center; font-size: 18px;
  }
  .name { font-size: 0.8rem; font-weight: 600; color: #111827; text-align: center; }
  .role { font-size: 0.7rem; color: #6b7280; text-align: center; }

  .box {
    background: rgba(255,255,255,1);
    border-radius: 16px; border: 1px solid white; padding: 16px;
  }
  #news {
    position: fixed; bottom: 16px; right: 16px;
    max-width: 320px; display: flex; gap: 12px; align-items: flex-start;
    backdrop-filter: blur(50px); transition: background 0.2s;
    text-decoration: none;
  }
  #news:hover { background: rgba(255,255,255,0.55); }
  .news-icon { font-size: 24px; }
  h2 { margin: 0 0 0.4em; font-weight: 600; color: #111827; font-size: 0.95rem; }
  #news p { color: #4b5563; font-size: 0.8rem; line-height: 1.4; margin: 0; }

  @media (max-width: 600px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
    #news { left: 16px; right: 16px; max-width: 100%; position: relative; margin: 1rem; }
  }
</style>